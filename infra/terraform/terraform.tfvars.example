# Copy to terraform.tfvars (gitignored) or export env vars.
# DO token: export DIGITALOCEAN_TOKEN=...  (provider also accepts do_token)

gcp_project   = "your-gcp-project-id"
gcp_region    = "us-central1"
do_region     = "nyc3"
domain        = "app.example.com"
environment   = "prod"
project_name  = "mockmatch"

# SSH / admin (edge droplet only)
admin_cidrs = ["203.0.113.10/32"]

doks_node_size = "s-2vcpu-4gb"
doks_min_nodes = 2
doks_max_nodes = 5

# After first image push to DOCR:
# api_image = "registry.digitalocean.com/mockmatch-prod/mockmatch-api:latest"

linkedin_client_id     = ""
linkedin_client_secret = ""

# Stripe (PCI: Checkout + Portal only; no card data in app)
stripe_secret_key          = ""
stripe_webhook_secret      = ""
stripe_price_credits_100   = ""
stripe_price_credits_500   = ""
stripe_price_credits_1000  = ""

create_dns_records = false
