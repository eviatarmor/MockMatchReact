{
  "name": "@mockmatch/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./router": {
      "types": "./src/trpc/index.ts",
      "default": "./src/trpc/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:schema:mermaid": "tsx scripts/generate-schema-mermaid.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.850.0",
    "@aws-sdk/s3-request-presigner": "^3.850.0",
    "@hono/node-server": "^1.14.4",
    "@hono/trpc-server": "^0.4.2",
    "@mockmatch/schemas": "*",
    "@openrouter/sdk": "^0.13.66",
    "@trpc/server": "^11.18.0",
    "bullmq": "^5.56.0",
    "dotenv": "^17.0.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.4",
    "ioredis": "^5.6.1",
    "jose": "^6.0.11",
    "nodemailer": "^9.0.3",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "playwright": "^1.61.1",
    "stripe": "^17.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.4",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
