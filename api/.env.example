DATABASE_URL=postgresql://mockmatch:mockmatch@localhost:5432/mockmatch
# Redis: OTP challenges + refresh token hashes (stateless multi-replica) + BullMQ
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=dev-only-change-me-access
JWT_REFRESH_SECRET=dev-only-change-me-refresh
# Fixed OTP for local dev only (empty = random 6-digit). Must be empty in production.
OTP_STUB_CODE=000000
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
# Optional real SMTP — leave empty to log email via nodemailer json transport
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MockMatch <noreply@mockmatch.local>
OPENROUTER_API_KEY=
# Cheap model for resume/cover-letter PDF import (text → JSON)
OPENROUTER_IMPORT_MODEL=google/gemini-2.0-flash-lite-001
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# LinkedIn OAuth (optional until portal + handlers wired)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/oauth/linkedin/callback
# Stripe (optional in local — leave empty for free-only billing UI)
# PCI: never put card numbers in app env/DB. Use Checkout + Customer Portal only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREDITS_100=
STRIPE_PRICE_CREDITS_500=
STRIPE_PRICE_CREDITS_1000=
FREE_CREDIT_GRANT=0
# PDF export (Playwright). Local: npx playwright install chromium
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
PDF_EXPORT_TIMEOUT_MS=30000
# Adzuna job search (optional — Discover page). Free keys: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOBS_CACHE_TTL_SECONDS=600
# Discover AI fit (paid credits only). Free users use heuristic scores.
OPENROUTER_FIT_MODEL=google/gemini-2.0-flash-lite-001
JOB_FIT_AI_CREDIT_COST=1
